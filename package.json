{
  "name": "@lapp-studio/react-toast-engine",
  "version": "0.0.4",
  "private": false,
  "type": "module",
  "main": "dist/core.js",
  "module": "dist/core.js",
  "types": "dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "require": "./dist/native.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "zustand": "^5.0.0",
    "react": "~19.0.0",
    "react-native": "~0.83.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "~0.7.2"
  },
  "peerDependencies": {
    "zustand": "^5.0.0",
    "react": "~19.0.0",
    "react-native": "^0.83.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "ˆ5.6.0",
    "react-native-worklets": "^0.7.2"
  },
  "maintainers": [
    "giovanninp"
  ],
  "keywords": [
    "react",
    "react-native",
    "toast",
    "notification",
    "snackbar",
    "alert",
    "headless",
